#!/usr/bin/env bash
# One-way Sync configuration files between this repo and $HOME.
#
#   sync-home to-home     # install repo files into $HOME
#   sync-home from-home   # pull $HOME files back into repo
#
# Also invokable as the symlinks `copy-to-home` / `copy-from-home`,
# in which case the direction is inferred from the invoked name.

set -euo pipefail

usage() {
    cat <<'EOF'
sync-home — one-way sync between this repo and $HOME.

Usage:
  sync-home [flags] to-home       install repo files into $HOME
  sync-home [flags] from-home     pull $HOME files back into this repo
  sync-home -h|--help             show this message

Flags (accepted before or after the direction):
  -i, --interactive   review each changed file; show a diff and prompt per file
  -n, --dry-run       print what would be copied; never write

Short flags may be combined (e.g. -in, -ni).

Symlink invocations (direction inferred from $0):
  copy-to-home            same as: sync-home to-home
  copy-from-home          same as: sync-home from-home

Without -i, both directions prompt once at the top before copying. With -i,
the per-file prompt supersedes the top-level confirmation.

Files that already match between source and destination are skipped silently
and reported in the summary (e.g. "3 copied, 12 skipped").

What gets synced is driven by three manifests. A file is only touched
if it appears in its manifest; files present on disk but absent from
the manifest are ignored. Blank lines and lines starting with '#' are
skipped.

  scripts/files     one name per line
                    scripts/<name>   <->  $HOME/.local/bin/<name>

  functions/files   one name per line
                    functions/<name> <->  $HOME/.local/functions/<name>

  dotfiles/files    two columns: <repo-name> <path-relative-to-$HOME>
                    dotfiles/<repo-name>  <->  $HOME/<path>
                    e.g.  "zshrc .zshrc"
                          "ssh/config .ssh/config"
                          "psqlrc-13 .psqlrc"   (version swap via manifest)

Missing parent directories under the destination are created as needed.
Copy failures are reported to stderr; the final summary is
"N copied[, M skipped][, K failed]" and the script exits non-zero if
anything failed.

Shared copy logic lives in lib/sync.sh.
EOF
}

opt_interactive=0
opt_dry_run=0
positional=()

parse_short_flags() {
    local chars="$1" c
    local i
    for (( i=0; i<${#chars}; i++ )); do
        c="${chars:$i:1}"
        case "$c" in
            i) opt_interactive=1 ;;
            n) opt_dry_run=1 ;;
            h) usage; exit 0 ;;
            *) printf 'Unknown flag: -%s\n\n' "$c" >&2; usage >&2; exit 2 ;;
        esac
    done
}

while (( $# )); do
    case "$1" in
        -h|--help)        usage; exit 0 ;;
        -i|--interactive) opt_interactive=1 ;;
        -n|--dry-run)     opt_dry_run=1 ;;
        --)               shift; positional+=("$@"); break ;;
        -*)               parse_short_flags "${1#-}" ;;
        *)                positional+=("$1") ;;
    esac
    shift
done

case "$(basename "$0")" in
    copy-to-home)   direction=to-home ;;
    copy-from-home) direction=from-home ;;
    *)              direction="${positional[0]:-}" ;;
esac

case "$direction" in
    to-home|from-home) ;;
    *)
        usage >&2
        exit 2
        ;;
esac

cd "$(dirname "$0")"
# shellcheck source=lib/sync.sh
source lib/sync.sh

SYNC_INTERACTIVE="$opt_interactive"
SYNC_DRY_RUN="$opt_dry_run"

if (( ! SYNC_INTERACTIVE )) && (( ! SYNC_DRY_RUN )); then
    if [[ $direction == to-home ]]; then
        confirm "Copy files from this repo to $HOME?" || exit 1
    else
        confirm "Copy files from $HOME to this repo?" || exit 1
    fi
fi

sync_list   scripts/files    scripts    "$HOME/.local/bin"        "$direction"
sync_list   functions/files  functions  "$HOME/.local/functions"  "$direction"
sync_mapped dotfiles/files   dotfiles   "$HOME"                   "$direction"

sync_summary
